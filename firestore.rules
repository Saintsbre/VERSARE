
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * VERSARE E-COMMERCE SECURITY RULES
     * Updated to ensure public pre-sell access
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function validatesRelationship(field, expectedValue) {
      return request.resource.data[field] == expectedValue;
    }

    // --- PUBLIC PRE-SELL ---
    // Permite que qualquer visitante envie seus dados de reserva
    match /pre-sell/{preSellId} {
      allow create: if true;
      allow read, update, delete: if false; 
    }

    // --- COLLECTION RULES ---

    match /collections/{collectionId} {
      allow get, list: if true;
      allow write: if false;
    }

    match /products/{productId} {
      allow get, list: if true;
      allow write: if false;
    }

    match /users/{userId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

    match /users/{userId}/addresses/{addressId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && validatesRelationship('userId', userId);
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

    match /users/{userId}/carts/{cartId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && validatesRelationship('userId', userId);
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

    match /users/{userId}/carts/{cartId}/items/{cartItemId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && validatesRelationship('userId', userId);
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

    match /users/{userId}/orders/{orderId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && validatesRelationship('userId', userId);
      allow update, delete: if false;
    }

    match /users/{userId}/orders/{orderId}/items/{orderItemId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && validatesRelationship('userId', userId);
      allow update, delete: if false;
    }
  }
}

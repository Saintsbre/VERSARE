{
  "entities": {
    "PreSell": {
      "title": "PreSell",
      "description": "Informações de reserva para o Drop Brazilidade 2026",
      "type": "object",
      "properties": {
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "whatsapp": { "type": "string" },
        "cep": { "type": "string" },
        "address": { "type": "string" },
        "number": { "type": "string" },
        "noNumber": { "type": "boolean" },
        "complement": { "type": "string" },
        "document": { "type": "string" },
        "newsletter": { "type": "boolean" },
        "selectedProducts": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "color": { "type": "string" },
              "size": { "type": "string" },
              "quantity": { "type": "string" }
            }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["firstName", "lastName", "email", "whatsapp", "document", "selectedProducts"]
    },
    "Product": {
      "title": "Product",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "number" },
        "image": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["anonymous"]
  },
  "firestore": {
    "/pre-sell/{preSellId}": {
      "schema": "PreSell",
      "description": "Coleção pública para capturar leads do pre-sell."
    }
  }
}
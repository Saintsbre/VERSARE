
{
  "entities": {
    "PreSave": {
      "title": "PreSave",
      "description": "Informações completas para reserva e futura entrega do drop exclusivo",
      "type": "object",
      "properties": {
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "whatsapp": { "type": "string" },
        "cep": { "type": "string" },
        "address": { "type": "string" },
        "number": { "type": "string" },
        "noNumber": { "type": "boolean" },
        "complement": { "type": "string" },
        "document": { "type": "string" },
        "newsletter": { "type": "boolean" },
        "selectedProducts": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "color": { "type": "string" },
              "size": { "type": "string" }
            },
            "required": ["name", "color", "size"]
          },
          "description": "Lista de peças selecionadas com cor e tamanho"
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["firstName", "lastName", "email", "whatsapp", "cep", "address", "document", "selectedProducts"]
    }
  },
  "auth": {
    "providers": ["anonymous"]
  },
  "firestore": {
    "/pre-save/{preSaveId}": {
      "schema": "PreSave",
      "description": "Coleção de cadastros de pré-save detalhados"
    }
  }
}

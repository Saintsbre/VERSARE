
{
  "requiredFirebaseServices": [
    "firestore"
  ],
  "entities": {
    "PreSell": {
      "title": "PreSell",
      "description": "Informações completas para reserva e futura entrega do drop exclusivo",
      "type": "object",
      "properties": {
        "firstName": {
          "type": "string"
        },
        "lastName": {
          "type": "string"
        },
        "email": {
          "type": "string"
        },
        "whatsapp": {
          "type": "string"
        },
        "cep": {
          "type": "string"
        },
        "address": {
          "type": "string"
        },
        "number": {
          "type": "string"
        },
        "noNumber": {
          "type": "boolean"
        },
        "complement": {
          "type": "string"
        },
        "document": {
          "type": "string",
          "description": "CPF ou CNPJ para nota fiscal"
        },
        "selectedProducts": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "color": { "type": "string" },
              "size": { "type": "string" },
              "quantity": { "type": "string" }
            },
            "required": ["name", "color", "size", "quantity"]
          }
        },
        "newsletter": {
          "type": "boolean"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "firstName",
        "lastName",
        "email",
        "whatsapp",
        "cep",
        "address",
        "document",
        "selectedProducts"
      ]
    }
  },
  "auth": {
    "providers": []
  },
  "firestore": {
    "/pre-sell/{preSellId}": {
      "schema": "PreSell",
      "description": "Coleção de cadastros de pré-venda detalhados"
    }
  }
}
